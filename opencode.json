{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.5",
  "small_model": "opencode-go-minimax/minimax-m2.5",
  "agent": {
    "build": {
      "model": "opencode-go/kimi-k2.5"
    },
    "plan": {
      "model": "opencode-go/glm-5"
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode-go-minimax/minimax-m2.5"
    },
    "code-reviewer": {
      "mode": "subagent",
      "description": "Reviews code for correctness, regressions, and clarity",
      "model": "opencode-go-minimax/minimax-m2.7",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    }
  }
}
