{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode-go": {}
  },
  "model": "opencode-go/minimax-m2.7",
  "small_model": "opencode-go/mimo-v2-pro-free",
  "default_agent": "build",
  "instructions": ["./AGENTS.md", "./PLAN.md", "./REVIEW.md", "./HARNESS.md"],
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "question": "allow",
    "webfetch": "allow",
    "bash": "allow",
    "edit": "allow",
    "task": "allow",
    "external_directory": "ask"
  },
  "share": "disabled",
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", "build/**", ".git/**", ".pi/**"]
  },
  "agent": {
    "build": {
      "description": "Default terminal-first Reckoner build agent",
      "mode": "primary",
      "model": "opencode-go/minimax-m2.7",
      "temperature": 0.2,
      "steps": 12,
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "task": {
          "*": "allow",
          "plan": "allow",
          "explore": "allow",
          "code-reviewer": "allow"
        }
      }
    },
    "plan": {
      "description": "Read-only analysis and implementation planning",
      "mode": "primary",
      "model": "opencode-go/mimo-v2-pro-free",
      "temperature": 0.1,
      "steps": 6,
      "permission": {
        "bash": "ask",
        "edit": "deny",
        "task": {
          "*": "deny",
          "explore": "allow"
        }
      }
    },
    "explore": {
      "description": "Fast read-only repository exploration",
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.5",
      "temperature": 0.1,
      "steps": 4,
      "hidden": true,
      "permission": {
        "bash": "allow",
        "edit": "deny"
      }
    },
    "code-reviewer": {
      "description": "Short, high-signal code review",
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.5",
      "temperature": 0.1,
      "steps": 4,
      "hidden": true,
      "permission": {
        "bash": "allow",
        "edit": "deny",
        "task": {
          "*": "deny"
        }
      }
    }
  }
}
