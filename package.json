{
  "name": "reckoner",
  "version": "0.1.0",
  "description": "Agent Workbench memory and policy package for persistent learning loops.",
  "keywords": ["pi-package", "coding-agent", "pi", "agent-workbench", "memory", "policy"],
  "author": "sainzs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sainzs/reckoner.git"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:unit",
    "test:unit": "tsx --test tests/**/*.test.ts",
    "verify:self": "npm run typecheck && npm run test:unit"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "pi": {
    "extensions": ["./extensions"],
    "skills": ["./skills"],
    "prompts": ["./prompts"],
    "themes": ["./themes"]
  }
}
